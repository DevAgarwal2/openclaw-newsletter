generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Release {
  id          String   @id @default(cuid())
  tagName     String   @unique
  name        String
  body        String   @db.Text
  publishedAt DateTime
  htmlUrl     String
  aiSummary   String?  @db.Text
  processedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tagName])
  @@index([publishedAt])
}